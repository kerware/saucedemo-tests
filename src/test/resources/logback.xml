<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender avec couleurs -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{30}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Fichier de log pour les tests -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>target/logs/saucedemo-tests.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>target/logs/saucedemo-tests.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Réduction du bruit Selenium -->
    <logger name="org.openqa.selenium" level="WARN"/>
    <logger name="io.github.bonigarcia"  level="WARN"/>
    <logger name="org.asynchttpclient"   level="WARN"/>

    <!-- Niveau DEBUG pour nos classes de test -->
    <logger name="com.saucedemo" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
